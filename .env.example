# Copy to .env for local testing:  cp .env.example .env  then fill in.
# Load before running:  set -a; source .env; set +a; python3 romano_bot.py
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
NEWS_API_KEY=
NEWS_PROVIDER=newsdata
# Journalists to follow. newsdata.io free tier caps this at 100 chars, so use
# surnames for all but Romano. Leave unset to use the built-in default.
NEWS_QUERY="Fabrizio Romano" OR Ornstein OR "Di Marzio" OR Moretto OR Amoyal OR Plettenberg
